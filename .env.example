# ============================================================
# BIẾN MÔI TRƯỜNG — HỆ THỐNG ĐĂNG KÝ HỌC PHẦN
# Sao chép file này thành .env rồi điền giá trị
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=course_registration
DB_CONNECTION_LIMIT=10

# --- Session ---
SESSION_SECRET=thay_bao_mat_nay_bang_chu_ngau_nhien
SESSION_MAX_AGE=86400000

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=10

# --- App ---
APP_NAME=Hệ Thống Đăng Ký Học Phần
APP_URL=http://localhost:3000

# --- Upload ---
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# --- Backup (Ubuntu) ---
BACKUP_DIR=/var/www/course-registration/database/backup
MYSQL_DUMP_PATH=/usr/bin/mysqldump
