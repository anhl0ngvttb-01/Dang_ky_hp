<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/student.css" />
  </head>
  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/student/dashboard">Sinh viên</a>
        <div class="d-flex gap-2">
          <a class="btn btn-outline-primary btn-sm" href="/student/profile">Hồ sơ</a>
          <a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a>
        </div>
      </div>
    </nav>
    <main class="container main-container py-4">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <h1 class="h4 mb-3">Đăng ký học phần</h1>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
          <form method="GET" action="/student/registrations" class="row g-3 align-items-end mb-3">
            <div class="col-md-6">
              <label class="form-label">Học kỳ</label>
              <select class="form-select" name="maHocKy" onchange="this.form.submit()">
                <% semesters.forEach(semester => { %>
                <option value="<%= semester.ma_hoc_ky_id %>" <%= Number(selectedSemesterId) === Number(semester.ma_hoc_ky_id) ? 'selected' : '' %>><%= semester.ten_hoc_ky %></option>
                <% }) %>
              </select>
            </div>
          </form>
          <form method="POST" action="/student/registrations" class="row g-3 align-items-end">
            <input type="hidden" name="maHocKy" value="<%= selectedSemesterId || '' %>" />
            <div class="col-md-9">
              <label class="form-label">Lớp học phần đang mở</label>
              <select class="form-select" name="maHocPhan" required>
                <% courses.forEach(course => { %>
                <option value="<%= course.ma_hoc_phan_id %>"><%= course.ma_hoc_phan %> - <%= course.ten_mon_hoc %> | Thứ <%= course.thu %>, tiết <%= course.tiet_bat_dau %>-<%= course.tiet_ket_thuc %> | <%= course.phong_hoc %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3"><button class="btn btn-primary w-100" <%= courses.length ? '' : 'disabled' %>>Đăng ký</button></div>
          </form>
        </div>
      </div>
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h2 class="h5 mb-3">Học phần đã đăng ký</h2>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead><tr><th>Mã lớp</th><th>Môn học</th><th>Lịch học</th><th>Phòng</th><th>Trạng thái</th><th></th></tr></thead>
              <tbody>
                <% registrationDetails.forEach(item => { %>
                <tr>
                  <td><%= item.ma_hoc_phan %></td>
                  <td><%= item.ten_mon_hoc %></td>
                  <td>Thứ <%= item.thu %>, tiết <%= item.tiet_bat_dau %>-<%= item.tiet_ket_thuc %></td>
                  <td><%= item.phong_hoc %></td>
                  <td><span class="badge text-bg-secondary"><%= item.trang_thai %></span></td>
                  <td class="text-end"><form method="POST" action="/student/registrations/cancel/<%= item.ma_chi_tiet %>"><button class="btn btn-sm btn-outline-danger">Hủy</button></form></td>
                </tr>
                <% }) %>
                <% if (!registrationDetails.length) { %><tr><td colspan="6" class="text-center text-secondary">Chưa có học phần nào.</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <script src="/js/student.js"></script>
  </body>
</html>
