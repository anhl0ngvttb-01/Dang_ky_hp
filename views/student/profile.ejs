<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/student.css" />
  </head>
  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/student/dashboard">Sinh viên</a>
        <div class="d-flex gap-2">
          <a class="btn btn-outline-primary btn-sm" href="/student/registrations">Đăng ký học phần</a>
          <a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a>
        </div>
      </div>
    </nav>
    <main class="container main-container py-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h1 class="h4 mb-3">Hồ sơ sinh viên</h1>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
          <% if (student) { %>
          <form method="POST" action="/student/profile" class="row g-3">
            <div class="col-md-6"><label class="form-label">Họ tên</label><input class="form-control" name="hoTen" value="<%= student.ho_ten || '' %>" required /></div>
            <div class="col-md-6"><label class="form-label">Mã sinh viên</label><input class="form-control" value="<%= student.ma_sinh_vien || '' %>" disabled /></div>
            <div class="col-md-6"><label class="form-label">Giới tính</label><select class="form-select" name="gioiTinh"><option value="Nam" <%= student.gioi_tinh === 'Nam' ? 'selected' : '' %>>Nam</option><option value="Nữ" <%= student.gioi_tinh === 'Nữ' ? 'selected' : '' %>>Nữ</option></select></div>
            <div class="col-md-6"><label class="form-label">Ngày sinh</label><input class="form-control" type="date" name="ngaySinh" value="<%= student.ngay_sinh ? student.ngay_sinh.toISOString().slice(0,10) : '' %>" /></div>
            <div class="col-md-6"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= student.email || '' %>" /></div>
            <div class="col-md-6"><label class="form-label">Số điện thoại</label><input class="form-control" name="soDienThoai" value="<%= student.so_dien_thoai || '' %>" /></div>
            <div class="col-md-4"><label class="form-label">Lớp</label><input class="form-control" name="lop" value="<%= student.lop || '' %>" required /></div>
            <div class="col-md-4"><label class="form-label">Ngành học</label><input class="form-control" name="nganhHoc" value="<%= student.nganh_hoc || '' %>" required /></div>
            <div class="col-md-4"><label class="form-label">Khóa</label><input class="form-control" name="khoa" value="<%= student.khoa || '' %>" required /></div>
            <div class="col-12"><label class="form-label">Địa chỉ</label><input class="form-control" name="diaChi" value="<%= student.dia_chi || '' %>" /></div>
            <div class="col-12"><button class="btn btn-primary">Lưu thay đổi</button></div>
          </form>
          <% } else { %>
          <div class="alert alert-warning mb-0">Chưa tìm thấy hồ sơ sinh viên cho tài khoản này.</div>
          <% } %>
        </div>
      </div>
    </main>
    <script src="/js/student.js"></script>
  </body>
</html>
