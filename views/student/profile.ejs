<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /><link rel="stylesheet" href="/css/student.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/student/dashboard"><span class="brand-mark">SV</span><span>Sinh vien</span></a><nav class="app-nav"><a href="/student/dashboard">Dashboard</a><a class="active" href="/student/profile">Ho so</a><a href="/student/registrations">Dang ky hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Ho so sinh vien</h1><p>Thong tin ca nhan va dao tao</p></div></div><section class="content-card"><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><% if (success) { %><div class="alert alert-success"><%= success %></div><% } %><% if (student) { %><form method="POST" action="/student/profile" class="row g-3"><div class="col-md-6"><label class="form-label">Ho ten</label><input class="form-control" name="hoTen" value="<%= student.ho_ten || '' %>" required /></div><div class="col-md-6"><label class="form-label">Ma sinh vien</label><input class="form-control" value="<%= student.ma_sinh_vien || '' %>" disabled /></div><div class="col-md-6"><label class="form-label">Gioi tinh</label><select class="form-select" name="gioiTinh"><option value="Nam" <%= student.gioi_tinh === 'Nam' ? 'selected' : '' %>>Nam</option><option value="Nữ" <%= student.gioi_tinh === 'Nữ' ? 'selected' : '' %>>Nu</option></select></div><div class="col-md-6"><label class="form-label">Ngay sinh</label><input class="form-control" type="date" name="ngaySinh" value="<%= student.ngay_sinh ? student.ngay_sinh.toISOString().slice(0,10) : '' %>" /></div><div class="col-md-6"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= student.email || '' %>" /></div><div class="col-md-6"><label class="form-label">So dien thoai</label><input class="form-control" name="soDienThoai" value="<%= student.so_dien_thoai || '' %>" /></div><div class="col-md-4"><label class="form-label">Lop</label><input class="form-control" name="lop" value="<%= student.lop || '' %>" required /></div><div class="col-md-4"><label class="form-label">Nganh hoc</label><input class="form-control" name="nganhHoc" value="<%= student.nganh_hoc || '' %>" required /></div><div class="col-md-4"><label class="form-label">Khoa</label><input class="form-control" name="khoa" value="<%= student.khoa || '' %>" required /></div><div class="col-12"><label class="form-label">Dia chi</label><input class="form-control" name="diaChi" value="<%= student.dia_chi || '' %>" /></div><div class="col-12"><button class="btn btn-primary">Luu thay doi</button></div></form><% } else { %><div class="alert alert-warning mb-0">Chua tim thay ho so sinh vien cho tai khoan nay.</div><% } %></section></main>
    </div><script src="/js/student.js"></script></body>
</html>