<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /><link rel="stylesheet" href="/css/student.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/student/dashboard"><span class="brand-mark">SV</span><span>Sinh vien</span></a><nav class="app-nav"><a class="active" href="/student/dashboard">Dashboard</a><a href="/student/profile">Ho so</a><a href="/student/registrations">Dang ky hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Dashboard sinh vien</h1><p><%= student ? student.ho_ten : user.tenDangNhap %></p></div><a class="btn btn-primary" href="/student/registrations">Dang ky hoc phan</a></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <div class="row g-3 mb-4"><div class="col-md-4"><div class="stat-card"><div class="stat-label">Hoc ky hien tai</div><div class="stat-value fs-4"><%= semester ? semester.ma_hoc_ky : '-' %></div><div class="stat-note"><%= semester ? semester.ten_hoc_ky : 'Chua co hoc ky' %></div></div></div><div class="col-md-4"><div class="stat-card"><div class="stat-label">Lop da dang ky</div><div class="stat-value"><%= registeredCourses || 0 %></div><div class="stat-note">Trang thai dang hoc</div></div></div><div class="col-md-4"><div class="stat-card"><div class="stat-label">Tin chi</div><div class="stat-value"><%= activeCredits || 0 %>/<%= maxCredits || 24 %></div><div class="stat-note">Gioi han hoc ky</div></div></div></div>
      <section class="content-card"><h2 class="section-title">Hoc phan gan day</h2><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma lop</th><th>Mon hoc</th><th>Lich hoc</th><th>Phong</th><th>Tin chi</th></tr></thead><tbody><% recentRegistrations.forEach(item => { %><tr><td class="fw-semibold"><%= item.ma_hoc_phan %></td><td><%= item.ten_mon_hoc %></td><td>Thu <%= item.thu %>, tiet <%= item.tiet_bat_dau %>-<%= item.tiet_ket_thuc %></td><td><%= item.phong_hoc %></td><td><%= item.so_tin_chi %></td></tr><% }) %><% if (!recentRegistrations.length) { %><tr><td colspan="5" class="text-center text-secondary py-4">Chua co hoc phan dang ky.</td></tr><% } %></tbody></table></div></section>
    </main></div><script src="/js/student.js"></script></body>
</html>