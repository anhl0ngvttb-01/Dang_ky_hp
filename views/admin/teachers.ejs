<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/students">Sinh viên</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Quản lý giảng viên</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã GV</th><th>Họ tên</th><th>Email</th><th>Bộ môn</th><th>Học hàm</th><th>Trạng thái</th></tr></thead><tbody><% teachers.forEach(teacher => { %><tr><td><%= teacher.ma_giang_vien %></td><td><%= teacher.ho_ten %></td><td><%= teacher.email || '' %></td><td><%= teacher.bo_mon || '' %></td><td><%= teacher.hoc_ham || '' %></td><td><span class="badge text-bg-secondary"><%= teacher.trang_thai %></span></td></tr><% }) %><% if (!teachers.length) { %><tr><td colspan="6" class="text-center text-secondary">Chưa có giảng viên.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>
