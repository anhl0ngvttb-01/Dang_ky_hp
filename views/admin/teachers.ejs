<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body>
    <div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a><nav class="app-nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/students">Sinh vien</a><a class="active" href="/admin/teachers">Giang vien</a><a href="/admin/subjects">Mon hoc</a><a href="/admin/semesters">Hoc ky</a><a href="/admin/courses">Lop hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
      <main class="app-main"><div class="topbar"><div class="page-title"><h1>Quan ly giang vien</h1><p><%= teachers.length %> ho so giang vien</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><section class="content-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma GV</th><th>Ho ten</th><th>Email</th><th>Bo mon</th><th>Hoc ham</th><th>Trang thai</th></tr></thead><tbody><% teachers.forEach(teacher => { %><tr><td class="fw-semibold"><%= teacher.ma_giang_vien %></td><td><%= teacher.ho_ten %></td><td><%= teacher.email || '' %></td><td><%= teacher.bo_mon || '' %></td><td><%= teacher.hoc_ham || '' %></td><td><span class="badge text-bg-secondary"><%= teacher.trang_thai %></span></td></tr><% }) %><% if (!teachers.length) { %><tr><td colspan="6" class="text-center text-secondary py-4">Chua co giang vien.</td></tr><% } %></tbody></table></div></section></main>
    </div>
  </body>
</html>