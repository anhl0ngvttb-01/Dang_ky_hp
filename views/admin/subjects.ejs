<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a><nav class="app-nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/students">Sinh vien</a><a href="/admin/teachers">Giang vien</a><a class="active" href="/admin/subjects">Mon hoc</a><a href="/admin/semesters">Hoc ky</a><a href="/admin/courses">Lop hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Quan ly mon hoc</h1><p><%= subjects.length %> mon hoc</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <section class="content-card mb-4"><h2 class="section-title">Them mon hoc</h2><form method="POST" action="/admin/subjects" class="row g-3"><div class="col-md-3"><label class="form-label">Ma mon</label><input class="form-control" name="maMonHoc" required /></div><div class="col-md-4"><label class="form-label">Ten mon</label><input class="form-control" name="tenMonHoc" required /></div><div class="col-md-2"><label class="form-label">So tin chi</label><input class="form-control" type="number" min="1" name="soTinChi" required /></div><div class="col-md-3"><label class="form-label">Mo ta</label><input class="form-control" name="moTa" /></div><div class="col-12"><button class="btn btn-primary">Them mon hoc</button></div></form></section>
      <section class="content-card"><h2 class="section-title">Danh sach mon hoc</h2><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma mon</th><th>Ten mon</th><th>So TC</th><th>Mo ta</th><th>Bat buoc</th></tr></thead><tbody><% subjects.forEach(subject => { %><tr><td class="fw-semibold"><%= subject.ma_mon_hoc %></td><td><%= subject.ten_mon_hoc %></td><td><%= subject.so_tin_chi %></td><td><%= subject.mo_ta || '' %></td><td><span class="badge <%= subject.bat_buoc ? 'text-bg-primary' : 'text-bg-secondary' %>"><%= subject.bat_buoc ? 'Co' : 'Khong' %></span></td></tr><% }) %><% if (!subjects.length) { %><tr><td colspan="5" class="text-center text-secondary py-4">Chua co mon hoc.</td></tr><% } %></tbody></table></div></section>
    </main></div></body>
</html>