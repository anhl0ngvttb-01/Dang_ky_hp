<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/subjects">Môn học</a><a class="btn btn-outline-primary btn-sm" href="/admin/semesters">Học kỳ</a><a class="btn btn-outline-primary btn-sm" href="/admin/courses">Lớp học phần</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Quản lý môn học</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><form method="POST" action="/admin/subjects" class="row g-3 align-items-end mb-4"><div class="col-md-3"><label class="form-label">Mã môn</label><input class="form-control" name="maMonHoc" required /></div><div class="col-md-3"><label class="form-label">Tên môn</label><input class="form-control" name="tenMonHoc" required /></div><div class="col-md-2"><label class="form-label">Số tín chỉ</label><input class="form-control" type="number" min="1" name="soTinChi" required /></div><div class="col-md-2"><label class="form-label">Mô tả</label><input class="form-control" name="moTa" /></div><div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div></form><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã môn</th><th>Tên môn</th><th>Số TC</th><th>Bắt buộc</th></tr></thead><tbody><% subjects.forEach(subject => { %><tr><td><%= subject.ma_mon_hoc %></td><td><%= subject.ten_mon_hoc %></td><td><%= subject.so_tin_chi %></td><td><%= subject.bat_buoc ? 'Có' : 'Không' %></td></tr><% }) %><% if (!subjects.length) { %><tr><td colspan="4" class="text-center text-secondary">Chưa có môn học.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>
