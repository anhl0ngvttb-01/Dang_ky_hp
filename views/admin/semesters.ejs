<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a><nav class="app-nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/students">Sinh vien</a><a href="/admin/teachers">Giang vien</a><a href="/admin/subjects">Mon hoc</a><a class="active" href="/admin/semesters">Hoc ky</a><a href="/admin/courses">Lop hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Quan ly hoc ky</h1><p><%= semesters.length %> hoc ky</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <section class="content-card mb-4"><h2 class="section-title">Them hoc ky</h2><form method="POST" action="/admin/semesters" class="row g-3"><div class="col-md-4"><label class="form-label">Ten hoc ky</label><input class="form-control" name="tenHocKy" required /></div><div class="col-md-2"><label class="form-label">Ma hoc ky</label><input class="form-control" name="maHocKy" required /></div><div class="col-md-3"><label class="form-label">Ngay bat dau</label><input class="form-control" type="date" name="ngayBatDau" required /></div><div class="col-md-3"><label class="form-label">Ngay ket thuc</label><input class="form-control" type="date" name="ngayKetThuc" required /></div><div class="col-md-3"><label class="form-label">Bat dau dang ky</label><input class="form-control" type="date" name="ngayBatDauDk" required /></div><div class="col-md-3"><label class="form-label">Ket thuc dang ky</label><input class="form-control" type="date" name="ngayKetThucDk" required /></div><div class="col-md-3"><label class="form-label">Trang thai</label><select class="form-select" name="trangThai"><option value="chua_mo">Chua mo</option><option value="dang_mo">Dang mo</option><option value="da_ket_thuc">Da ket thuc</option></select></div><div class="col-12"><button class="btn btn-primary">Them hoc ky</button></div></form></section>
      <section class="content-card"><h2 class="section-title">Danh sach hoc ky</h2><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma HK</th><th>Ten hoc ky</th><th>Ngay hoc</th><th>Dang ky</th><th>Trang thai</th></tr></thead><tbody><% semesters.forEach(semester => { %><tr><td class="fw-semibold"><%= semester.ma_hoc_ky %></td><td><%= semester.ten_hoc_ky %></td><td><%= semester.ngay_bat_dau %> - <%= semester.ngay_ket_thuc %></td><td><%= semester.ngay_bat_dau_dk %> - <%= semester.ngay_ket_thuc_dk %></td><td><span class="badge text-bg-secondary"><%= semester.trang_thai %></span></td></tr><% }) %><% if (!semesters.length) { %><tr><td colspan="5" class="text-center text-secondary py-4">Chua co hoc ky.</td></tr><% } %></tbody></table></div></section>
    </main></div></body>
</html>