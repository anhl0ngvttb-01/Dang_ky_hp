<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/subjects">Môn học</a><a class="btn btn-outline-primary btn-sm" href="/admin/courses">Lớp học phần</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Quản lý học kỳ</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><form method="POST" action="/admin/semesters" class="row g-3 align-items-end mb-4"><div class="col-md-3"><label class="form-label">Tên học kỳ</label><input class="form-control" name="tenHocKy" required /></div><div class="col-md-2"><label class="form-label">Mã học kỳ</label><input class="form-control" name="maHocKy" required /></div><div class="col-md-2"><label class="form-label">Ngày bắt đầu</label><input class="form-control" type="date" name="ngayBatDau" required /></div><div class="col-md-2"><label class="form-label">Ngày kết thúc</label><input class="form-control" type="date" name="ngayKetThuc" required /></div><div class="col-md-2"><label class="form-label">Bắt đầu ĐK</label><input class="form-control" type="date" name="ngayBatDauDk" required /></div><div class="col-md-2"><label class="form-label">Kết thúc ĐK</label><input class="form-control" type="date" name="ngayKetThucDk" required /></div><div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div></form><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã HK</th><th>Tên học kỳ</th><th>Ngày bắt đầu</th><th>Ngày kết thúc</th><th>Bắt đầu ĐK</th><th>Kết thúc ĐK</th><th>Trạng thái</th></tr></thead><tbody><% semesters.forEach(semester => { %><tr><td><%= semester.ma_hoc_ky %></td><td><%= semester.ten_hoc_ky %></td><td><%= semester.ngay_bat_dau %></td><td><%= semester.ngay_ket_thuc %></td><td><%= semester.ngay_bat_dau_dk %></td><td><%= semester.ngay_ket_thuc_dk %></td><td><span class="badge text-bg-secondary"><%= semester.trang_thai %></span></td></tr><% }) %><% if (!semesters.length) { %><tr><td colspan="7" class="text-center text-secondary">Chưa có học kỳ.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>
