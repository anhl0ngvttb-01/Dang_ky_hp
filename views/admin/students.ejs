<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body>
    <div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a><nav class="app-nav"><a href="/admin/dashboard">Dashboard</a><a class="active" href="/admin/students">Sinh vien</a><a href="/admin/teachers">Giang vien</a><a href="/admin/subjects">Mon hoc</a><a href="/admin/semesters">Hoc ky</a><a href="/admin/courses">Lop hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
      <main class="app-main"><div class="topbar"><div class="page-title"><h1>Quan ly sinh vien</h1><p><%= students.length %> ho so sinh vien</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><section class="content-card mb-4"><div class="d-flex align-items-center justify-content-between mb-3"><div><h2 class="section-title mb-1">Them sinh vien moi</h2><p class="text-secondary mb-0">Nhap day du thong tin sinh vien. Mat khau mac dinh la 123456.</p></div></div><form action="/admin/students" method="POST" class="row g-3"><div class="col-md-6"><label class="form-label">Ten dang nhap</label><input type="text" name="tenDangNhap" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Email</label><input type="email" name="email" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Ma sinh vien</label><input type="text" name="maSinhVien" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Ho ten</label><input type="text" name="hoTen" class="form-control" required /></div><div class="col-md-3"><label class="form-label">Gioi tinh</label><select name="gioiTinh" class="form-select"><option value="Nam" selected>Nam</option><option value="Nữ">Nữ</option></select></div><div class="col-md-3"><label class="form-label">Ngay sinh</label><input type="date" name="ngaySinh" class="form-control" /></div><div class="col-md-3"><label class="form-label">So dien thoai</label><input type="tel" name="soDienThoai" class="form-control" /></div><div class="col-md-3"><label class="form-label">Dia chi</label><input type="text" name="diaChi" class="form-control" /></div><div class="col-md-4"><label class="form-label">Lop</label><input type="text" name="lop" class="form-control" required /></div><div class="col-md-4"><label class="form-label">Nganh hoc</label><input type="text" name="nganhHoc" class="form-control" required /></div><div class="col-md-4"><label class="form-label">Khoa</label><input type="text" name="khoa" class="form-control" required /></div><div class="col-12"><button class="btn btn-primary" type="submit">Tao sinh vien</button></div></form></section><section class="content-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma SV</th><th>Ho ten</th><th>Lop</th><th>Nganh</th><th>Khoa</th><th>Trang thai</th></tr></thead><tbody><% students.forEach(student => { %><tr><td class="fw-semibold"><%= student.ma_sinh_vien %></td><td><%= student.ho_ten %></td><td><%= student.lop %></td><td><%= student.nganh_hoc %></td><td><%= student.khoa %></td><td><span class="badge text-bg-secondary"><%= student.trang_thai %></span></td></tr><% }) %><% if (!students.length) { %><tr><td colspan="6" class="text-center text-secondary py-4">Chua co sinh vien.</td></tr><% } %></tbody></table></div></section></main>
    </div>
  </body>
</html>