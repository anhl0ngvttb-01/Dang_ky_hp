<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/teachers">Giảng viên</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Quản lý sinh viên</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã SV</th><th>Họ tên</th><th>Lớp</th><th>Ngành</th><th>Khóa</th><th>Trạng thái</th></tr></thead><tbody><% students.forEach(student => { %><tr><td><%= student.ma_sinh_vien %></td><td><%= student.ho_ten %></td><td><%= student.lop %></td><td><%= student.nganh_hoc %></td><td><%= student.khoa %></td><td><span class="badge text-bg-secondary"><%= student.trang_thai %></span></td></tr><% }) %><% if (!students.length) { %><tr><td colspan="6" class="text-center text-secondary">Chưa có sinh viên.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>
