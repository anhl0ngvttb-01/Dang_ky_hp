<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a><nav class="app-nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/students">Sinh vien</a><a href="/admin/teachers">Giang vien</a><a href="/admin/subjects">Mon hoc</a><a href="/admin/semesters">Hoc ky</a><a class="active" href="/admin/courses">Lop hoc phan</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Quan ly lop hoc phan</h1><p><%= courses.length %> lop hoc phan</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <section class="content-card mb-4"><h2 class="section-title">Them lop hoc phan</h2><form method="POST" action="/admin/courses" class="row g-3"><div class="col-md-2"><label class="form-label">Ma lop</label><input class="form-control" name="maHocPhan" required /></div><div class="col-md-2"><label class="form-label">ID mon</label><input class="form-control" type="number" name="maMonHoc" required /></div><div class="col-md-2"><label class="form-label">ID giang vien</label><input class="form-control" type="number" name="maGiangVien" required /></div><div class="col-md-2"><label class="form-label">ID hoc ky</label><input class="form-control" type="number" name="maHocKy" required /></div><div class="col-md-2"><label class="form-label">Phong</label><input class="form-control" name="phongHoc" required /></div><div class="col-md-1"><label class="form-label">Thu</label><input class="form-control" type="number" min="2" max="8" name="thu" required /></div><div class="col-md-1"><label class="form-label">TC</label><input class="form-control" type="number" min="1" name="soTinChi" required /></div><div class="col-md-2"><label class="form-label">Tiet bat dau</label><input class="form-control" type="number" min="1" max="12" name="tietBatDau" required /></div><div class="col-md-2"><label class="form-label">Tiet ket thuc</label><input class="form-control" type="number" min="1" max="12" name="tietKetThuc" required /></div><div class="col-md-2"><label class="form-label">Si so toi da</label><input class="form-control" type="number" min="1" name="soSvMax" value="50" /></div><div class="col-12"><button class="btn btn-primary">Them lop</button></div></form></section>
      <section class="content-card"><h2 class="section-title">Danh sach lop hoc phan</h2><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma lop</th><th>Mon hoc</th><th>Giang vien</th><th>Hoc ky</th><th>Lich</th><th>Phong</th><th>Si so</th><th>Trang thai</th></tr></thead><tbody><% courses.forEach(course => { %><tr><td class="fw-semibold"><%= course.ma_hoc_phan %></td><td><%= course.ten_mon_hoc || course.ma_mon_hoc %></td><td><%= course.ten_giang_vien || course.ma_giang_vien %></td><td><%= course.ten_hoc_ky || course.ma_hoc_ky %></td><td>Thu <%= course.thu %>, tiet <%= course.tiet_bat_dau %>-<%= course.tiet_ket_thuc %></td><td><%= course.phong_hoc %></td><td><%= course.so_sv_hien_tai %>/<%= course.so_sv_max %></td><td><span class="badge text-bg-secondary"><%= course.trang_thai %></span></td></tr><% }) %><% if (!courses.length) { %><tr><td colspan="8" class="text-center text-secondary py-4">Chua co lop hoc phan.</td></tr><% } %></tbody></table></div></section>
    </main></div></body>
</html>