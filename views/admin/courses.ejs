<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/subjects">Môn học</a><a class="btn btn-outline-primary btn-sm" href="/admin/semesters">Học kỳ</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Quản lý lớp học phần</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><form method="POST" action="/admin/courses" class="row g-3 align-items-end mb-4"><div class="col-md-2"><label class="form-label">Mã lớp</label><input class="form-control" name="maHocPhan" required /></div><div class="col-md-2"><label class="form-label">ID môn</label><input class="form-control" type="number" name="maMonHoc" required /></div><div class="col-md-2"><label class="form-label">ID GV</label><input class="form-control" type="number" name="maGiangVien" required /></div><div class="col-md-2"><label class="form-label">ID học kỳ</label><input class="form-control" type="number" name="maHocKy" required /></div><div class="col-md-2"><label class="form-label">Phòng</label><input class="form-control" name="phongHoc" required /></div><div class="col-md-1"><label class="form-label">Thứ</label><input class="form-control" type="number" min="2" max="8" name="thu" required /></div><div class="col-md-1"><label class="form-label">TC</label><input class="form-control" type="number" min="1" name="soTinChi" required /></div><div class="col-md-2"><label class="form-label">Tiết bắt đầu</label><input class="form-control" type="number" min="1" max="12" name="tietBatDau" required /></div><div class="col-md-2"><label class="form-label">Tiết kết thúc</label><input class="form-control" type="number" min="1" max="12" name="tietKetThuc" required /></div><div class="col-md-2"><button class="btn btn-primary w-100">Thêm lớp</button></div></form><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã lớp</th><th>ID môn</th><th>ID GV</th><th>ID HK</th><th>Lịch</th><th>Phòng</th><th>Trạng thái</th></tr></thead><tbody><% courses.forEach(course => { %><tr><td><%= course.ma_hoc_phan %></td><td><%= course.ma_mon_hoc %></td><td><%= course.ma_giang_vien %></td><td><%= course.ma_hoc_ky %></td><td>Thứ <%= course.thu %>, tiết <%= course.tiet_bat_dau %>-<%= course.tiet_ket_thuc %></td><td><%= course.phong_hoc %></td><td><span class="badge text-bg-secondary"><%= course.trang_thai %></span></td></tr><% }) %><% if (!courses.length) { %><tr><td colspan="7" class="text-center text-secondary">Chưa có lớp học phần.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>

