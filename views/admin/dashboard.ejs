<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="app-sidebar">
        <a class="app-brand" href="/admin/dashboard"><span class="brand-mark">AD</span><span>Quan tri</span></a>
        <nav class="app-nav">
          <a class="active" href="/admin/dashboard">Dashboard</a>
          <a href="/admin/students">Sinh vien</a>
          <a href="/admin/teachers">Giang vien</a>
          <a href="/admin/subjects">Mon hoc</a>
          <a href="/admin/semesters">Hoc ky</a>
          <a href="/admin/courses">Lop hoc phan</a>
          <a href="/auth/logout">Dang xuat</a>
        </nav>
      </aside>
      <main class="app-main">
        <div class="topbar"><div class="page-title"><h1>Bang dieu khien quan tri</h1><p>Tong quan du lieu dao tao</p></div></div>
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
        <div class="row g-3 mb-4">
          <div class="col-md"><div class="stat-card"><div class="stat-label">Sinh vien</div><div class="stat-value"><%= overview.students || 0 %></div><div class="stat-note">Ho so dang quan ly</div></div></div>
          <div class="col-md"><div class="stat-card"><div class="stat-label">Giang vien</div><div class="stat-value"><%= overview.teachers || 0 %></div><div class="stat-note">Tai khoan giang day</div></div></div>
          <div class="col-md"><div class="stat-card"><div class="stat-label">Lop hoc phan</div><div class="stat-value"><%= overview.courses || 0 %></div><div class="stat-note">Lop da mo</div></div></div>
          <div class="col-md"><div class="stat-card"><div class="stat-label">Mon hoc</div><div class="stat-value"><%= overview.subjects || 0 %></div><div class="stat-note">Trong chuong trinh</div></div></div>
          <div class="col-md"><div class="stat-card"><div class="stat-label">Hoc ky</div><div class="stat-value"><%= overview.semesters || 0 %></div><div class="stat-note">Ky dao tao</div></div></div>
        </div>
        <div class="quick-grid">
          <a class="action-card" href="/admin/subjects"><div class="section-title">Mon hoc</div><p class="text-secondary mb-0">Cap nhat danh muc mon va tin chi.</p></a>
          <a class="action-card" href="/admin/semesters"><div class="section-title">Hoc ky</div><p class="text-secondary mb-0">Mo dot va thoi gian dang ky.</p></a>
          <a class="action-card" href="/admin/courses"><div class="section-title">Lop hoc phan</div><p class="text-secondary mb-0">Phan cong giang vien, phong va lich.</p></a>
        </div>
      </main>
    </div>
  </body>
</html>