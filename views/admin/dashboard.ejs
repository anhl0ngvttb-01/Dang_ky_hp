<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/admin/dashboard">Quản trị</a><div class="d-flex flex-wrap gap-2"><a class="btn btn-outline-primary btn-sm" href="/admin/students">Sinh viên</a><a class="btn btn-outline-primary btn-sm" href="/admin/teachers">Giảng viên</a><a class="btn btn-outline-primary btn-sm" href="/admin/subjects">Môn học</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><h1 class="h4 mb-3">Bảng điều khiển quản trị</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><div class="row g-3"><div class="col-md"><div class="p-3 bg-white rounded border shadow-sm"><div class="fs-3 fw-semibold"><%= overview.students || 0 %></div><div class="text-secondary">Sinh viên</div></div></div><div class="col-md"><div class="p-3 bg-white rounded border shadow-sm"><div class="fs-3 fw-semibold"><%= overview.teachers || 0 %></div><div class="text-secondary">Giảng viên</div></div></div><div class="col-md"><div class="p-3 bg-white rounded border shadow-sm"><div class="fs-3 fw-semibold"><%= overview.courses || 0 %></div><div class="text-secondary">Lớp học phần</div></div></div><div class="col-md"><div class="p-3 bg-white rounded border shadow-sm"><div class="fs-3 fw-semibold"><%= overview.subjects || 0 %></div><div class="text-secondary">Môn học</div></div></div><div class="col-md"><div class="p-3 bg-white rounded border shadow-sm"><div class="fs-3 fw-semibold"><%= overview.semesters || 0 %></div><div class="text-secondary">Học kỳ</div></div></div></div></main>
  </body>
</html>
