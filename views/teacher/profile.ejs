<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/teacher/dashboard"><span class="brand-mark">GV</span><span>Giang vien</span></a><nav class="app-nav"><a href="/teacher/dashboard">Dashboard</a><a class="active" href="/teacher/profile">Ho so</a><a href="/teacher/courses">Lop day</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Ho so giang vien</h1><p>Thong tin giang day</p></div></div><section class="content-card"><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><% if (success) { %><div class="alert alert-success"><%= success %></div><% } %><% if (teacher) { %><form method="POST" action="/teacher/profile" class="row g-3"><div class="col-md-6"><label class="form-label">Ho ten</label><input class="form-control" name="hoTen" value="<%= teacher.ho_ten || '' %>" required /></div><div class="col-md-6"><label class="form-label">Ma giang vien</label><input class="form-control" value="<%= teacher.ma_giang_vien || '' %>" disabled /></div><div class="col-md-6"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= teacher.email || '' %>" /></div><div class="col-md-6"><label class="form-label">So dien thoai</label><input class="form-control" name="soDienThoai" value="<%= teacher.so_dien_thoai || '' %>" /></div><div class="col-md-6"><label class="form-label">Bo mon</label><input class="form-control" name="boMon" value="<%= teacher.bo_mon || '' %>" /></div><div class="col-md-6"><label class="form-label">Hoc ham</label><input class="form-control" name="hocHam" value="<%= teacher.hoc_ham || '' %>" /></div><div class="col-12"><button class="btn btn-primary">Luu thay doi</button></div></form><% } else { %><div class="alert alert-warning mb-0">Chua tim thay ho so giang vien cho tai khoan nay.</div><% } %></section></main>
    </div></body>
</html>