<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/teacher/dashboard">Giảng viên</a><div class="d-flex gap-2"><a class="btn btn-outline-primary btn-sm" href="/teacher/courses">Lớp dạy</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Hồ sơ giảng viên</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><% if (success) { %><div class="alert alert-success"><%= success %></div><% } %><% if (teacher) { %><form method="POST" action="/teacher/profile" class="row g-3"><div class="col-md-6"><label class="form-label">Họ tên</label><input class="form-control" name="hoTen" value="<%= teacher.ho_ten || '' %>" required /></div><div class="col-md-6"><label class="form-label">Mã giảng viên</label><input class="form-control" value="<%= teacher.ma_giang_vien || '' %>" disabled /></div><div class="col-md-6"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= teacher.email || '' %>" /></div><div class="col-md-6"><label class="form-label">Số điện thoại</label><input class="form-control" name="soDienThoai" value="<%= teacher.so_dien_thoai || '' %>" /></div><div class="col-md-6"><label class="form-label">Bộ môn</label><input class="form-control" name="boMon" value="<%= teacher.bo_mon || '' %>" /></div><div class="col-md-6"><label class="form-label">Học hàm</label><input class="form-control" name="hocHam" value="<%= teacher.hoc_ham || '' %>" /></div><div class="col-12"><button class="btn btn-primary">Lưu thay đổi</button></div></form><% } else { %><div class="alert alert-warning mb-0">Chưa tìm thấy hồ sơ giảng viên cho tài khoản này.</div><% } %></div></div></main>
  </body>
</html>
