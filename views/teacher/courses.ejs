<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/teacher/dashboard"><span class="brand-mark">GV</span><span>Giang vien</span></a><nav class="app-nav"><a href="/teacher/dashboard">Dashboard</a><a href="/teacher/profile">Ho so</a><a class="active" href="/teacher/courses">Lop day</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Danh sach lop hoc phan</h1><p><%= courses.length %> lop phu trach</p></div></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><section class="content-card"><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma lop</th><th>Mon hoc</th><th>Hoc ky</th><th>Lich</th><th>Phong</th><th>Si so</th><th>Trang thai</th><th class="text-end">Thao tac</th></tr></thead><tbody><% courses.forEach(course => { %><tr><td class="fw-semibold"><%= course.ma_hoc_phan %></td><td><%= course.ten_mon_hoc || course.ma_mon_hoc %></td><td><%= course.ten_hoc_ky || '' %></td><td>Thu <%= course.thu %>, tiet <%= course.tiet_bat_dau %>-<%= course.tiet_ket_thuc %></td><td><%= course.phong_hoc %></td><td><%= course.so_sv_hien_tai %>/<%= course.so_sv_max %></td><td><span class="badge text-bg-secondary"><%= course.trang_thai %></span></td><td><form method="POST" action="/teacher/courses/status/<%= course.ma_hoc_phan_id %>" class="d-flex justify-content-end gap-2"><select name="trangThai" class="form-select form-select-sm" style="max-width: 170px"><option value="mo_dang_ky" <%= course.trang_thai === 'mo_dang_ky' ? 'selected' : '' %>>Mo dang ky</option><option value="khoa_dang_ky" <%= course.trang_thai === 'khoa_dang_ky' ? 'selected' : '' %>>Khoa dang ky</option><option value="huy_lop" <%= course.trang_thai === 'huy_lop' ? 'selected' : '' %>>Huy lop</option></select><button class="btn btn-sm btn-primary">Cap nhat</button></form></td></tr><% }) %><% if (!courses.length) { %><tr><td colspan="8" class="text-center text-secondary py-4">Chua co lop hoc phan.</td></tr><% } %></tbody></table></div></section></main>
    </div></body>
</html>