<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /></head>
  <body class="bg-body-tertiary">
    <nav class="navbar bg-white border-bottom"><div class="container"><a class="navbar-brand" href="/teacher/dashboard">Giảng viên</a><div class="d-flex gap-2"><a class="btn btn-outline-primary btn-sm" href="/teacher/profile">Hồ sơ</a><a class="btn btn-outline-danger btn-sm" href="/auth/logout">Đăng xuất</a></div></div></nav>
    <main class="container py-4"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-3">Danh sách lớp học phần</h1><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Mã lớp</th><th>Phòng</th><th>Sĩ số</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead><tbody><% courses.forEach(course => { %><tr><td><%= course.ma_hoc_phan %></td><td><%= course.phong_hoc %></td><td><%= course.so_sv_hien_tai %>/<%= course.so_sv_max %></td><td><span class="badge text-bg-secondary"><%= course.trang_thai %></span></td><td><form method="POST" action="/teacher/courses/status/<%= course.ma_hoc_phan_id %>" class="d-flex justify-content-end gap-2"><select name="trangThai" class="form-select form-select-sm" style="max-width: 170px"><option value="mo_dang_ky" <%= course.trang_thai === 'mo_dang_ky' ? 'selected' : '' %>>Mở đăng ký</option><option value="khoa_dang_ky" <%= course.trang_thai === 'khoa_dang_ky' ? 'selected' : '' %>>Khóa đăng ký</option><option value="huy_lop" <%= course.trang_thai === 'huy_lop' ? 'selected' : '' %>>Hủy lớp</option></select><button class="btn btn-sm btn-primary">Cập nhật</button></form></td></tr><% }) %><% if (!courses.length) { %><tr><td colspan="5" class="text-center text-secondary">Chưa có lớp học phần.</td></tr><% } %></tbody></table></div></div></div></main>
  </body>
</html>
