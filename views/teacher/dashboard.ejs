<!DOCTYPE html>
<html lang="vi">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="/css/app.css" /></head>
  <body><div class="app-shell"><aside class="app-sidebar"><a class="app-brand" href="/teacher/dashboard"><span class="brand-mark">GV</span><span>Giang vien</span></a><nav class="app-nav"><a class="active" href="/teacher/dashboard">Dashboard</a><a href="/teacher/profile">Ho so</a><a href="/teacher/courses">Lop day</a><a href="/auth/logout">Dang xuat</a></nav></aside>
    <main class="app-main"><div class="topbar"><div class="page-title"><h1>Dashboard giang vien</h1><p><%= teacher ? teacher.ho_ten : user.tenDangNhap %></p></div><a class="btn btn-primary" href="/teacher/courses">Quan ly lop</a></div><% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <div class="row g-3 mb-4"><div class="col-md-3"><div class="stat-card"><div class="stat-label">Tong lop</div><div class="stat-value"><%= overview.total || 0 %></div><div class="stat-note">Lop phu trach</div></div></div><div class="col-md-3"><div class="stat-card"><div class="stat-label">Dang mo</div><div class="stat-value"><%= overview.open || 0 %></div><div class="stat-note">Mo dang ky</div></div></div><div class="col-md-3"><div class="stat-card"><div class="stat-label">Da khoa</div><div class="stat-value"><%= overview.locked || 0 %></div><div class="stat-note">Khoa dang ky</div></div></div><div class="col-md-3"><div class="stat-card"><div class="stat-label">Huy lop</div><div class="stat-value"><%= overview.cancelled || 0 %></div><div class="stat-note">Khong mo lop</div></div></div></div>
      <section class="content-card"><h2 class="section-title">Lop phu trach gan day</h2><div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Ma lop</th><th>Mon hoc</th><th>Hoc ky</th><th>Lich</th><th>Si so</th><th>Trang thai</th></tr></thead><tbody><% courses.forEach(course => { %><tr><td class="fw-semibold"><%= course.ma_hoc_phan %></td><td><%= course.ten_mon_hoc %></td><td><%= course.ten_hoc_ky %></td><td>Thu <%= course.thu %>, tiet <%= course.tiet_bat_dau %>-<%= course.tiet_ket_thuc %></td><td><%= course.so_sv_hien_tai %>/<%= course.so_sv_max %></td><td><span class="badge text-bg-secondary"><%= course.trang_thai %></span></td></tr><% }) %><% if (!courses.length) { %><tr><td colspan="6" class="text-center text-secondary py-4">Chua co lop hoc phan.</td></tr><% } %></tbody></table></div></section>
    </main></div></body>
</html>