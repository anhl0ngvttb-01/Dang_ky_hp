<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/app.css" rel="stylesheet" />
  </head>
  <body>
    <main class="auth-page">
      <section class="auth-panel">
        <div class="app-brand px-0"><span class="brand-mark">HP</span><span>He thong dang ky hoc phan</span></div>
        <div>
          <h1>Quan ly dang ky hoc phan </h1>

        </div>
        <div class="text-white-50 small">Academic Portal</div>
      </section>
      <section class="auth-wrap">
        <div class="auth-card">
          <div class="mb-4">
            <h2 class="h3 mb-1">Dang nhap</h2>
            <p class="text-secondary mb-0">He thong dang ky hoc phan</p>
          </div>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <form action="/auth/login" method="POST" class="vstack gap-3">
            <div>
              <label class="form-label">Ten dang nhap</label>
              <input type="text" name="tenDangNhap" class="form-control" value="<%= form.tenDangNhap || '' %>" autocomplete="username" required />
            </div>
            <div>
              <label class="form-label">Mat khau</label>
              <input type="password" name="matKhau" class="form-control" autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Dang nhap</button>
          </form>
          <p class="text-center text-secondary mt-4 mb-0"></p>
        </div>
      </section>
    </main>
  </body>
</html>