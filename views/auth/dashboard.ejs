<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/app.css" rel="stylesheet" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="app-sidebar">
        <a class="app-brand" href="/auth/dashboard"><span class="brand-mark">HP</span><span>Tai khoan</span></a>
        <nav class="app-nav">
          <a class="active" href="/auth/dashboard">Tong quan</a>
          <a href="/student/dashboard">Sinh vien</a>
          <a href="/teacher/dashboard">Giang vien</a>
          <a href="/admin/dashboard">Quan tri</a>
          <a href="/auth/logout">Dang xuat</a>
        </nav>
      </aside>
      <main class="app-main">
        <div class="topbar"><div class="page-title"><h1>Xin chao, <%= user.tenDangNhap %></h1><p>Vai tro hien tai: <strong><%= user.roleName %></strong></p></div></div>
        <div class="quick-grid">
          <a class="action-card" href="/student/dashboard"><div class="section-title">Khu sinh vien</div><p class="text-secondary mb-0">Ho so va dang ky hoc phan</p></a>
          <a class="action-card" href="/teacher/dashboard"><div class="section-title">Khu giang vien</div><p class="text-secondary mb-0">Lop phu trach va trang thai lop</p></a>
          <a class="action-card" href="/admin/dashboard"><div class="section-title">Khu quan tri</div><p class="text-secondary mb-0">Du lieu dao tao va hoc phan</p></a>
        </div>
      </main>
    </div>
  </body>
</html>